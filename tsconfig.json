{
	"compilerOptions": {
		"target": "es2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "5.0",
		"outDir": "dist",
		"types": ["node"]
	},
	"include": ["src/**/*", "test/**/*"]
}
